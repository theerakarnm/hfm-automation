# ── Web App Login ──────────────────────────────────────────────────────────────
# Hardcoded credentials for the internal web login page
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# ── Session ────────────────────────────────────────────────────────────────────
# Random secret used to sign session cookies — MUST be changed in production
# Generate one: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME_use_openssl_rand_base64_32

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
