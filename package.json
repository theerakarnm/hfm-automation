{
  "name": "hfm-automation",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "trigger:daily-client-report": "bun run scripts/trigger-daily-client-report.ts",
    "fetch:client-performance": "bun run scripts/fetch-client-performance-range.ts",
    "compare:client-performance": "bun run scripts/compare-client-performance-files.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "croner": "^10.0.1",
    "dayjs": "^1.11.20",
    "hono": "^4.12.15",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0"
  }
}
